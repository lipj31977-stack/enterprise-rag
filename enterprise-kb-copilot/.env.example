# ============================================================
# 企业知识库 Copilot — 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ---------- 聊天大模型 配置 ----------
OPENAI_API_KEY=        #deeepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
# 聊天模型
LLM_MODEL_NAME=deepseek-chat

# ---------- 向量 Embedding 模型配置 ----------
EMBEDDING_API_KEY=                         #qwenapi_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 嵌入模型 (Qwen的embedding模型: text-embedding-v3)
EMBEDDING_MODEL_NAME=text-embedding-v3

# ---------- MySQL 配置 ----------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=kb_copilot_2026
MYSQL_DATABASE=kb_copilot

# ---------- FastAPI 配置 ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- Streamlit 配置 ----------
BACKEND_URL=http://backend:8000

# ---------- 文档处理配置 ----------
# 文本切分大小
CHUNK_SIZE=500
# 切分重叠
CHUNK_OVERLAP=50
# 检索返回的 top_k 数量
RETRIEVER_TOP_K=4

# ---------- 文件存储路径 ----------
UPLOAD_DIR=./data/uploads
VECTOR_STORE_DIR=./data/vector_store
